{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@wwdrew/expo-apple-music": [
        "../build/index"
      ],
      "@wwdrew/expo-apple-music/plugin": [
        "../plugin/build/index"
      ],
      "expo-apple-music": [
        "../src/index"
      ],
      "expo-apple-music/*": [
        "../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
