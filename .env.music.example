# Copy to .env.music (gitignored) for npm run dev-token
# See docs/CLI.md — MusicKit key: Apple Developer → Keys

APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# Optional: comma-separated browser origins for web JWT origin claim
# APPLE_MUSIC_ORIGINS=http://localhost:8081,https://music.example.com
