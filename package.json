{
  "name": "@wwdrew/expo-apple-music",
  "version": "1.0.0",
  "description": "Apple MusicKit wrapper for Expo",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build && expo-module build plugin",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "jest --watchman=false",
    "test:expo": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "node scripts/npm-prepublish.mjs && expo-module prepublishOnly",
    "pack:check": "npm run build && node scripts/verify-npm-pack.mjs",
    "expo-module": "expo-module",
    "dev-token": "node scripts/generate-developer-token.mjs",
    "sync:fixtures": "node scripts/sync-android-fixtures.mjs",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "apple-music",
    "music-kit",
    "musickit",
    "ios",
    "android",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wwdrew/expo-apple-music.git"
  },
  "bugs": {
    "url": "https://github.com/wwdrew/expo-apple-music/issues"
  },
  "author": "Drew <49833875+wwdrew@users.noreply.github.com> (https://github.com/wwdrew)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/wwdrew/expo-apple-music/tree/main/docs",
  "files": [
    "app.plugin.js",
    "expo-module.config.json",
    "build",
    "plugin/build",
    "ios",
    "android/build.gradle",
    "android/src/main",
    "android/libs",
    "LICENSE",
    "NOTICE",
    "ATTRIBUTION.md"
  ],
  "expo": {
    "plugin": "./app.plugin.js"
  },
  "devDependencies": {
    "@expo/config-plugins": "^56.0.7",
    "@types/node": "^22.10.0",
    "@types/react": "~19.1.1",
    "eslint": "^9.39.0",
    "expo": "^56.0.3",
    "expo-module-scripts": "^56.0.2",
    "jest": "^29.7.0",
    "react": "^19.1.0",
    "react-native": "^0.85.3",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.3"
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./plugin": {
      "types": "./plugin/build/index.d.ts",
      "default": "./plugin/build/index.js"
    }
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=9.0.0",
    "expo": "^56.0.0",
    "expo-modules-core": "*",
    "react": "*",
    "react-native": "*"
  }
}
